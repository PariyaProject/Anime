# Local development:
#   copy to .env.local so `npm run dev` can read your machine-local settings.
# Docker deployment:
#   copy to .env so `docker compose` can substitute the values below.

BACKEND_PORT=3006
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:3006

# Docker / production runtime
NODE_ENV=production
PORT=3006
RATE_LIMIT_DELAY=1000
ANIME_DATA_DIR=./config

# Required for private-site mode.
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=anime-admin-2026

# Set to 1 only if you must allow http cookies in a non-https production-like environment.
AUTH_COOKIE_INSECURE=0
