# ============================================
# MINIMAL DOCKER CONTEXT - ONLY BUILD REQUIREMENTS
# ============================================

# Dependencies (reinstalled during build)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Runtime data (mounted as volumes)
config/
logs/
data/

# ALL documentation
*.md
README*
LICENSE
.txt
CHANGELOG*
CONTRIBUTING*

# Git and version control
.git/
.gitignore
.gitattributes

# CI/CD and pipelines
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml
Jenkinsfile

# OpenSpec specifications
openspec/

# IDE and editors
.vscode/
.idea/
.editorconfig
*.swp
*.swo
*~

# Test files and coverage
coverage/
*.test.js
*.spec.js
.vitest/
playwright-report/
test-results/
__tests__/
*.test.ts
*.spec.ts

# Development configuration
.env*
dev.config.*
*.local

# Build artifacts (shouldn't exist in source)
dist/
build/
out/
*.tgz
*.tar

# Scripts and tools
scripts/
tools/
.devcontainer/

# Testing and debug data
data/testing/
data/debug/
data/archive/
*.log
*.tmp
*.bak

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Root level configs (not needed for build, but needed in subdirs)
/.eslintrc*
/.prettierrc*
/.pretttierrc
/tsconfig.json
/vite.config.*
/vitest.config.*
/playwright.config.*
/.npmrc
/.yarnrc
/.yarnrc.yml
/babel.config.*
/webpack.config.*

# Docker files (not needed in image context)
docker-compose*.yml
docker-compose*.yaml
Dockerfile*
.dockerignore

# Misc and temporary files
*.map
*.tsbuildinfo
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.yarn/
.pnp.*
